# CrewAI Configuration Template
# Copy this to .env and fill in your actual API keys

# LLM Configuration - Choose your provider
# Option 1: OpenAI (most common)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_NAME=gpt-4o

# Option 2: NVIDIA NIM (as configured in this project)
MODEL=minimaxai/minimax-m2.7
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key-here

# Option 3: Other Providers
# ANTHROPIC_API_KEY=your-anthropic-key
# GROQ_API_KEY=your-groq-key
# COHERE_API_KEY=your-cohere-key

# Web Search Tool
# Get free API key from https://serper.dev/
SERPER_API_KEY=your-serper-api-key-here

# CrewAI Settings
CREW_VERBOSE=True

# Optional: Output configuration
# CREW_OUTPUT_LOG_FILE=crew.log
